// ═══════════════════════════════════════════════════════════════════
// HIGHSTRIKE ORB — OPTIONS  (SPY / QQQ · US RTH only · 0DTE entry, max 4-DTE hold)
// Translates the validated STACK signal (same engine as HIGHSTRIKE_ORB_STACK: HH/HL structure gate +
// VWAP cap + structure stop + ATR trail) into option structures on the RTH opening range:
//   • NAKED BUY  — long call (long bias) / long put (short bias), BUY ONLY, never naked short.
//                  Strike = 1-2 ITM / ATM / 1-2 OTM (input; 1 ITM default = delta that tracks the move).
//   • DEBIT  spread — long the chosen strike, short the strike at TP1 (cheapens entry, caps at target).
//   • CREDIT spread — defined-risk vertical on the OTHER side: short strike at the STRUCTURE STOP
//                  (price has to break the stop to hurt it), long protection 1 width beyond.
//   • EXPIRY — 0DTE for same-day momentum; if holding, the FURTHEST allowed expiry is +4 trading
//                  days (dashboard shows both dates). Exit the moment the underlying crosses the trail.
// SCOPE: SPY + QQQ for now (dashboard warns elsewhere) — expand later. RTH only (options session).
// ⚠️ The validated underlying edge is INTRADAY (EOD-flat). 0DTE = the researched profile. Holding a
//    spread to ≤4 DTE is an options-layer allowance (defined-risk carries the gap), NOT separately
//    backtested — prefer 0DTE on naked longs (theta) and reserve multi-day holds for spreads.
// LIMITATION: Pine has NO options-chain / IV / premium / Greeks access. This outputs STRIKES +
// STRUCTURE + THESIS only — price the contracts at the broker before entering.
// ═══════════════════════════════════════════════════════════════════
//@version=6
indicator("HIGHSTRIKE ORB Options", overlay=true, max_labels_count=100)

// ───────────────────────── INPUTS ─────────────────────────
long_on  = input.bool(true, "LONG signals",  group="Direction", inline="d")
short_on = input.bool(true, "SHORT signals", group="Direction", inline="d")
or_start = input.session("0930-1000", "Opening Range window (ET)", group="ORB")
sess_tz  = input.string("America/New_York", "Timezone", options=["America/New_York","America/Chicago","Europe/London"], group="ORB")
trade_end_hhmm = input.int(1500, "Stop new signals after HHMM (ET)", group="ORB", minval=0, maxval=2359)
brk_buf_atr = input.float(0.10, "Breakout strength (clear OR by x ATR)", group="ORB", step=0.05, minval=0.0)
auto_tf  = input.bool(true, "Auto breakout buffer per TF", group="ORB", tooltip="<=5m -> 0.0, else 0.25 ATR. OFF = manual.")
allow_reentry = input.bool(false, "Allow re-entry (re-arm inside OR)", group="ORB",
            tooltip="OFF = one signal per side per day (validated default). ON = re-arm when price falls back inside the OR; capped by Max entries.")
max_entries  = input.int(2, "Max entries per side / day", group="ORB", minval=1)
// ───────────────────────── STRUCTURE GATE (stack engine) ─────────────────────────
trend_mode = input.string("Auto (structure <=5m / EMA >=15m)", "Trend gate", group="Structure gate",
             options=["Auto (structure <=5m / EMA >=15m)", "Structure (HH/HL)", "EMA trend"])
struct_lb  = input.int(5, "Structure pivot lookback (L=R)", group="Structure gate", minval=2)
struct_tol = input.float(0.10, "Structure tolerance %", group="Structure gate", step=0.05)
trend_ema_f = input.int(21, "Trend EMA fast (EMA mode)", group="Structure gate", minval=2)
trend_ema_s = input.int(50, "Trend EMA slow (EMA mode)", group="Structure gate", minval=5)
// ───────────────────────── VWAP CAP ─────────────────────────
cap_on = input.bool(true, "VWAP-extension cap", group="VWAP cap")
cap_k  = input.float(2.0, "Cap k (xATR beyond VWAP)", group="VWAP cap", step=0.25, minval=0.5)
// ───────────────────────── REGIME ─────────────────────────
local_adx_min = input.float(20.0, "Local ADX min", group="Regime", step=1)
local_atr_hi  = input.float(2.5,  "Volatile ATR%",  group="Regime", step=0.25)
block_range   = input.bool(true,  "Block RANGE regime", group="Regime")
macro_en       = input.bool(true,  "MACRO filter ON", group="Regime")
macro_standdown= input.bool(true,  "Stand-down vs SPY trend", group="Regime")
spy_sym  = input.symbol("SPY",      "Macro trend ref", group="Regime")
vix_sym  = input.symbol("CBOE:VIX", "Macro vol ref",   group="Regime")
vix_calm = input.float(15.0, "VIX calm",     group="Regime", step=1)
vix_vol  = input.float(25.0, "VIX volatile", group="Regime", step=1)
vix_ext  = input.float(35.0, "VIX extreme",  group="Regime", step=1)
spy_adx_min = input.float(25.0, "Macro ADX min", group="Regime", step=1)
persist_n   = input.int(3, "Regime persistence bars", group="Regime", minval=1)
block_d     = input.bool(true, "Block REGIME D", group="Regime")
block_b     = input.bool(true, "Block trend in REGIME B", group="Regime")
// ───────────────────────── RISK PLAN (graduated: structure stop + trail) ─────────────────────────
stop_mode = input.string("Structure swing (HH/HL)", "Stop placement", group="Risk plan",
            options=["Structure swing (HH/HL)", "OR edge"],
            tooltip="F25b: stop at the last HH/HL swing ~halves the risk. The credit-spread short strike sits here.")
sl_buf_atr  = input.float(0.3, "Stop buffer beyond anchor x ATR", group="Risk plan", step=0.1)
min_stop_atr= input.float(0.5, "Min stop x ATR", group="Risk plan", step=0.1)
sl_max_atr  = input.float(2.5, "Max stop x ATR", group="Risk plan", step=0.25)
trail_atr   = input.float(2.0, "Trail x ATR (chandelier — exit signal)", group="Risk plan", step=0.5, minval=0.5,
              tooltip="F27b: exit the option when the UNDERLYING crosses the trail. Spreads can also just run to their strikes.")
tp1_rr      = input.float(1.0, "TP1 R (debit-spread cap strike)", group="Risk plan", step=0.25)
tp2_rr      = input.float(4.0, "TP2 R (display target; exit = trail)", group="Risk plan", step=0.25)
// ───────────────────────── OPTIONS ─────────────────────────
strike_sel  = input.string("1 ITM", "Naked-buy strike", group="Options",
              options=["2 ITM", "1 ITM", "ATM", "1 OTM", "2 OTM"],
              tooltip="1-2 ITM = higher delta, tracks the underlying move (default). 1-2 OTM = cheaper convexity, needs the move to run. The dashboard shows the whole ladder.")
strike_inc  = input.float(1.0, "Strike increment $", group="Options", step=0.5, minval=0.5,
              tooltip="SPY/QQQ trade $1 strikes (0.5 exists near the money on 0DTE).")
spread_w    = input.float(3.0, "Spread width $ (protection / cap leg)", group="Options", step=1.0, minval=1.0)
max_dte     = input.int(4, "Max DTE hold (trading days)", group="Options", minval=0, maxval=10,
              tooltip="0DTE to enter; if holding, never past this expiry. Default 4.")
strat_sel   = input.string("Debit spread", "STRAT row: preferred structure", group="Options",
              options=["Naked buy", "Debit spread", "Credit spread"])
est_on      = input.bool(true, "COST row: rough premium estimate", group="Options",
              tooltip="Pine has NO option-chain access — this is a Black-Scholes APPROXIMATION from the IV input below, for sizing intuition only (marked ~). The real premium is at the broker.")
iv_pct      = input.float(20.0, "IV % for the estimate", group="Options", step=1, minval=1)
est_dte     = input.int(0, "Estimate DTE (0 = 0DTE)", group="Options", minval=0, maxval=10)
show_table  = input.bool(true, "Show options dashboard", group="Options")
show_levels = input.bool(true, "Show OR + level lines", group="Options")
show_line_labels = input.bool(true, "Write ENTRY / STOP / TP on the chart", group="Options")

// ───────────────────────── CORE ─────────────────────────
atr14 = ta.atr(14)
[dip, dim, adxV] = ta.dmi(14, 14)
atr_pct = close > 0 ? atr14 / close * 100.0 : 0.0
emaF = ta.ema(close, trend_ema_f)
emaS = ta.ema(close, trend_ema_s)
bool trend_up   = close > emaS and emaF > emaS
bool trend_down = close < emaS and emaF < emaS
float vwap_c = ta.vwap
int o_now = hour(time, sess_tz) * 60 + minute(time, sess_tz)
bool new_day = ta.change(time("D")) != 0
bool wkday = dayofweek != dayofweek.saturday and dayofweek != dayofweek.sunday
int tf_s = timeframe.in_seconds()
float eff_brk = auto_tf ? (tf_s <= 300 ? 0.0 : 0.25) : brk_buf_atr
int trade_end = (trade_end_hhmm / 100) * 60 + (trade_end_hhmm % 100)
bool sym_ok = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ"

// ───────────────────────── HH/HL STRUCTURE STATE (port of hs_harness.py; pivot_tie='tv' per F28) ─────────────────────────
float ph = ta.pivothigh(high, struct_lb, struct_lb)
float pl = ta.pivotlow(low,  struct_lb, struct_lb)
var float ph_last = na
var float ph_prev = na
var float pl_last = na
var float pl_prev = na
var int   st_state = 0
int st_prev = st_state
if not na(ph)
    if na(ph_last) or math.abs(ph - ph_last) / ph_last * 100.0 >= struct_tol
        ph_prev := ph_last
        ph_last := ph
if not na(pl)
    if na(pl_last) or math.abs(pl - pl_last) / pl_last * 100.0 >= struct_tol
        pl_prev := pl_last
        pl_last := pl
bool s_hh = not na(ph_last) and not na(ph_prev) and ph_last > ph_prev
bool s_lh = not na(ph_last) and not na(ph_prev) and ph_last < ph_prev
bool s_hl = not na(pl_last) and not na(pl_prev) and pl_last > pl_prev
bool s_ll = not na(pl_last) and not na(pl_prev) and pl_last < pl_prev
if s_hh and s_hl
    st_state := 1
else if s_ll and s_lh
    st_state := 2
else if (s_hh and s_ll) or (s_hl and s_lh)
    st_state := 3
if st_prev == 2 and not na(ph_last) and close > ph_last and close[1] <= ph_last
    st_state := 0
if st_prev == 1 and not na(pl_last) and close < pl_last and close[1] >= pl_last
    st_state := 0
bool use_struct = trend_mode == "Structure (HH/HL)" or (trend_mode == "Auto (structure <=5m / EMA >=15m)" and tf_s <= 300)
bool eff_up   = use_struct ? (st_state == 1) : trend_up
bool eff_down = use_struct ? (st_state == 2) : trend_down

// ───────────────────────── MACRO REGIME ─────────────────────────
spy_b() =>
    [_a,_b,sadx] = ta.dmi(14,14)
    [close, ta.ema(close,20), ta.ema(close,50), sadx]
vix_b() => ta.sma(close,5)
[spc, se20, se50, sadx] = request.security(spy_sym, "D", spy_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vix5 = request.security(vix_sym, "D", vix_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
bool spy_up = not na(spc) and spc > se20 and se20 > se50
bool spy_dn = not na(spc) and spc < se20 and se20 < se50
bool spy_trend = (spy_up or spy_dn) and not na(sadx) and sadx >= spy_adx_min
string reg_raw = "-"
if not na(vix5)
    reg_raw := vix5 >= vix_ext ? "D" : vix5 >= vix_vol ? "C" : (vix5 < vix_calm and spy_trend) ? "A" : (vix5 < vix_vol and not spy_trend) ? "B" : spy_trend ? "A" : "B"
var int reg_cnt = 0
var string reg_pend = "-"
var string reg_conf = "-"
int need = reg_raw == "D" ? 0 : persist_n
if reg_raw == "D"
    reg_conf := "D"
    reg_pend := "D"
    reg_cnt := need
else if reg_raw == reg_pend
    reg_cnt += 1
    if reg_cnt >= need
        reg_conf := reg_raw
else
    reg_pend := reg_raw
    reg_cnt := 1
string regime = reg_conf != "-" ? reg_conf : reg_raw
bool macro_allow = not macro_en or not ((regime == "D" and block_d) or (regime == "B" and block_b))
bool macro_long_ok  = not macro_en or not macro_standdown or not spy_dn
bool macro_short_ok = not macro_en or not macro_standdown or not spy_up
int local_regime = atr_pct >= local_atr_hi ? 3 : adxV >= local_adx_min ? 1 : 2
bool local_ok = not block_range or local_regime != 2

// ───────────────────────── OPENING RANGE + LEVELS ─────────────────────────
bool in_or = not na(time(timeframe.period, or_start, sess_tz))
var float or_high = na
var float or_low  = na
var bool  or_set  = false
if new_day
    or_high := na
    or_low  := na
    or_set  := false
if in_or
    or_high := na(or_high) ? high : math.max(or_high, high)
    or_low  := na(or_low)  ? low  : math.min(or_low,  low)
if not in_or and not na(or_high)
    or_set := true
float brk_buf = atr14 * eff_brk
var float Le = na
var float Se = na
var bool  traded_l = false
var bool  traded_s = false
var int   n_l = 0
var int   n_s = 0
if new_day
    Le := na
    Se := na
    traded_l := false
    traded_s := false
    n_l := 0
    n_s := 0
if or_set and na(Le) and not na(or_high) and not na(or_low)
    Le := or_high + brk_buf
    Se := or_low  - brk_buf
// stop anchor: last HH/HL swing (structure) or the OR edge. Recomputed while ARMED, frozen at fill.
var bool in_long  = false
var bool in_short = false
float anchorL = (stop_mode == "Structure swing (HH/HL)" and not na(pl_last)) ? pl_last : or_low
float anchorS = (stop_mode == "Structure swing (HH/HL)" and not na(ph_last)) ? ph_last : or_high
var float Ls = na
var float Ss = na
if not na(Le) and not in_long
    Ls := math.min(math.max(anchorL - atr14 * sl_buf_atr, Le - atr14 * sl_max_atr), Le - atr14 * min_stop_atr)
if not na(Se) and not in_short
    Ss := math.max(math.min(anchorS + atr14 * sl_buf_atr, Se + atr14 * sl_max_atr), Se + atr14 * min_stop_atr)
float Lt1 = na(Le) or na(Ls) ? na : Le + (Le - Ls) * tp1_rr
float St1 = na(Se) or na(Ss) ? na : Se - (Ss - Se) * tp1_rr
float Lt2 = na(Le) or na(Ls) ? na : Le + (Le - Ls) * tp2_rr
float St2 = na(Se) or na(Ss) ? na : Se - (Ss - Se) * tp2_rr

// ───────────────────────── VWAP CAP + GATES + FIRING ─────────────────────────
float extL = na(Le) ? na : (Le - vwap_c) / atr14
float extS = na(Se) ? na : (vwap_c - Se) / atr14
bool cap_long_ok  = not cap_on or na(extL) or extL <= cap_k
bool cap_short_ok = not cap_on or na(extS) or extS <= cap_k
bool window = or_set and wkday and o_now < trade_end and not na(Le)
bool gate_long  = long_on  and eff_up   and macro_allow and macro_long_ok  and local_ok
bool gate_short = short_on and eff_down  and macro_allow and macro_short_ok and local_ok
if allow_reentry and traded_l and not na(or_high) and close < or_high and n_l < max_entries
    traded_l := false
if allow_reentry and traded_s and not na(or_low) and close > or_low and n_s < max_entries
    traded_s := false
bool sig_l = window and not traded_l and gate_long  and high >= Le
bool sig_s = window and not traded_s and gate_short and low  <= Se
bool long_fire  = sig_l and cap_long_ok
bool short_fire = sig_s and cap_short_ok
bool long_skip  = sig_l and not cap_long_ok
bool short_skip = sig_s and not cap_short_ok
if sig_l
    traded_l := true
    n_l += 1
if sig_s
    traded_s := true
    n_s += 1

// ───────────────────────── IN-TRADE: trail on the underlying = the option EXIT signal ─────────────────────────
var float lstop = na
var float sstop = na
var bool l_t1h = false      // TP1 / TP2 touched (state machine + dashboard tags)
var bool l_t2h = false
var bool s_t1h = false
var bool s_t2h = false
var string stL = "WAIT"     // per-side trade state: WAIT/ARMED/FILLED/NEAR TP1/TP1 HIT/TP2 HIT/STOP HIT
var string stS = "WAIT"
// in-trade state text, shared by both sides (NEAR TP1 = 75% of the way to TP1)
f_tstate(t2h, t1h, near_tp1) => t2h ? "TP2 HIT" : t1h ? "TP1 HIT" : near_tp1 ? "NEAR TP1" : "FILLED"
if new_day
    in_long  := false
    in_short := false
    lstop := na
    sstop := na
    l_t1h := false
    l_t2h := false
    s_t1h := false
    s_t2h := false
    stL := "WAIT"
    stS := "WAIT"
if long_fire
    in_long := true
    lstop := Ls
    l_t1h := false
    l_t2h := false
if short_fire
    in_short := true
    sstop := Ss
    s_t1h := false
    s_t2h := false
if in_long
    lstop := math.max(lstop, close - trail_atr * atr14)
    if high >= Lt1
        l_t1h := true
    if high >= Lt2
        l_t2h := true
    stL := f_tstate(l_t2h, l_t1h, close >= Le + 0.75 * (Lt1 - Le))
    if low <= lstop
        in_long := false
        if not l_t1h
            stL := "STOP HIT"
if in_short
    sstop := math.min(sstop, close + trail_atr * atr14)
    if low <= St1
        s_t1h := true
    if low <= St2
        s_t2h := true
    stS := f_tstate(s_t2h, s_t1h, close <= Se - 0.75 * (Se - St1))
    if high >= sstop
        in_short := false
        if not s_t1h
            stS := "STOP HIT"
bool exit_l = in_long[1] and not in_long
bool exit_s = in_short[1] and not in_short
bool l_live = (window and not traded_l and gate_long) or in_long
bool s_live = (window and not traded_s and gate_short) or in_short
float l_stop_now = in_long ? lstop : Ls
float s_stop_now = in_short ? sstop : Ss
// flat-side state refresh (final states persist once the side has traded)
bool armL = window and not traded_l and gate_long and cap_long_ok
bool armS = window and not traded_s and gate_short and cap_short_ok
if not in_long and not traded_l
    stL := armL ? "ARMED" : "WAIT"
if not in_short and not traded_s
    stS := armS ? "ARMED" : "WAIT"
// state colors (user legend): WAIT gray · ARMED yellow · FILLED blue · NEAR TP1 light green · TP1 HIT green · TP2 HIT dark green · STOP HIT red
f_stc(s) => s == "WAIT" ? color.gray : s == "ARMED" ? color.yellow : s == "FILLED" ? color.rgb(41, 121, 255) :
     s == "NEAR TP1" ? color.rgb(144, 238, 144) : s == "TP1 HIT" ? color.green : s == "TP2 HIT" ? color.rgb(0, 102, 0) : color.red

// ───────────────────────── OPTIONS TRANSLATION (1-2 ITM/OTM · 0-4 DTE · buy-only + verticals) ─────────────────────────
f_round(p) => math.round(p / strike_inc) * strike_inc
f_floor(p) => math.floor(p / strike_inc) * strike_inc
f_ceil(p)  => math.ceil(p / strike_inc)  * strike_inc
f_px(p) => str.tostring(p, "#.##")
// strike n steps ITM (n>0) / OTM (n<0) / ATM (0) relative to the entry level, side-aware
f_strike_n(e, isl, n) =>
    float k = na
    if n == 0
        k := f_round(e)
    else if n > 0
        k := isl ? f_floor(e) - (n - 1) * strike_inc : f_ceil(e) + (n - 1) * strike_inc
    else
        k := isl ? f_ceil(e) + (-n - 1) * strike_inc : f_floor(e) - (-n - 1) * strike_inc
    k
int sel_n = strike_sel == "2 ITM" ? 2 : strike_sel == "1 ITM" ? 1 : strike_sel == "1 OTM" ? -1 : strike_sel == "2 OTM" ? -2 : 0
bool have = or_set and not na(Le) and not na(Se)
// expiries: 0DTE today · furthest allowed hold = +max_dte TRADING days
f_addtd(t0, n) =>
    int t1 = t0
    int added = 0
    while added < n
        t1 += 86400000
        int dw = dayofweek(t1, sess_tz)
        if dw != dayofweek.saturday and dw != dayofweek.sunday
            added += 1
    t1
int t_max = f_addtd(time, max_dte)
string exp_txt = "0DTE " + str.tostring(month(time)) + "/" + str.tostring(dayofmonth(time)) +
     "  ·  max hold " + str.tostring(max_dte) + "DTE " + str.tostring(month(t_max)) + "/" + str.tostring(dayofmonth(t_max))
// ── per-side strikes for the LONG|SHORT dashboard ──
float kNl = have ? f_strike_n(Le, true,  sel_n) : na     // naked-buy strikes
float kNs = have ? f_strike_n(Se, false, sel_n) : na
float dsl = have ? f_round(Lt1) : na                     // debit-spread short legs (cap @ TP1)
float dss = have ? f_round(St1) : na
float csl = have ? f_round(l_stop_now) : na              // credit-spread short legs (@ the stop)
float css = have ? f_round(s_stop_now) : na
float cll = csl - spread_w
float cls = css + spread_w
// ── rough premium estimate (Black-Scholes; NO chain access in Pine — sizing intuition only) ──
f_ncdf(x) =>
    float tt = 1.0 / (1.0 + 0.2316419 * math.abs(x))
    float dn = 0.3989423 * math.exp(-x * x / 2.0)
    float pp = dn * tt * (0.3193815 + tt * (-0.3565638 + tt * (1.781478 + tt * (-1.821256 + tt * 1.330274))))
    x >= 0 ? 1.0 - pp : pp
f_bs(S, K, isCall) =>
    float v = math.max(iv_pct, 1.0) / 100.0
    float T = (math.max(est_dte, 0) + 0.5) / 252.0
    float d1 = (math.log(S / K) + 0.5 * v * v * T) / (v * math.sqrt(T))
    float d2 = d1 - v * math.sqrt(T)
    isCall ? S * f_ncdf(d1) - K * f_ncdf(d2) : K * f_ncdf(-d2) - S * f_ncdf(-d1)
f_strat(isl, kN, ds, cs, cl) =>
    strat_sel == "Naked buy" ? "Buy " + (isl ? "Call " : "Put ") + f_px(kN) :
     strat_sel == "Debit spread" ? "Debit " + (isl ? "Call " : "Put ") + f_px(kN) + "/" + f_px(ds) :
     "Credit " + (isl ? "Put " : "Call ") + f_px(cs) + "/" + f_px(cl)
f_cost(isl, kN, ds, cs, cl) =>
    string out = "@ broker"
    if est_on and not na(kN)
        float c = strat_sel == "Naked buy" ? f_bs(close, kN, isl) :
             strat_sel == "Debit spread" ? f_bs(close, kN, isl) - f_bs(close, ds, isl) :
             f_bs(close, cs, not isl) - f_bs(close, cl, not isl)
        out := (strat_sel == "Credit spread" ? "~ +$" : "~ $") + str.tostring(math.max(c, 0) * 100, "#")
    out
f_grade(trendok, gateok, capok) => not trendok ? "—" : gateok and capok and regime == "A" ? "A+" : gateok and capok ? "A" : gateok ? "B" : "C"

// ───────────────────────── VISUALS ─────────────────────────
plot(show_levels and or_set ? or_high : na, "OR high", color=color.new(color.aqua, 70),   style=plot.style_linebr)
plot(show_levels and or_set ? or_low  : na, "OR low",  color=color.new(color.orange, 70), style=plot.style_linebr)
plot(show_levels and l_live ? Le : na, "Long entry",  color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
plot(show_levels and s_live ? Se : na, "Short entry", color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
plot(show_levels and l_live ? l_stop_now : na, "Long stop",  color=color.new(color.red, 25),  style=plot.style_linebr)
plot(show_levels and s_live ? s_stop_now : na, "Short stop", color=color.new(color.red, 25),  style=plot.style_linebr)
plot(show_levels and l_live ? Lt1 : na, "Long TP1 (debit cap)",  color=color.new(color.green, 10), style=plot.style_linebr)
plot(show_levels and s_live ? St1 : na, "Short TP1 (debit cap)", color=color.new(color.green, 10), style=plot.style_linebr)
plot(show_levels and l_live ? Lt2 : na, "Long TP2",  color=color.new(color.green, 45), style=plot.style_linebr)
plot(show_levels and s_live ? St2 : na, "Short TP2", color=color.new(color.green, 45), style=plot.style_linebr)
plotshape(long_fire,  "Long fire",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), text="CALL", textcolor=color.white, size=size.tiny)
plotshape(short_fire, "Short fire", shape.triangledown, location.abovebar, color.new(color.red, 0),  text="PUT",  textcolor=color.white, size=size.tiny)
plotshape(long_skip,  "Long capped",  shape.xcross, location.belowbar, color.new(color.gray, 0), text="EXT", textcolor=color.gray, size=size.tiny)
plotshape(short_skip, "Short capped", shape.xcross, location.abovebar, color.new(color.gray, 0), text="EXT", textcolor=color.gray, size=size.tiny)
plotshape(exit_l, "Exit long",  shape.square, location.abovebar, color.new(color.orange, 0), text="EXIT", textcolor=color.white, size=size.tiny)
plotshape(exit_s, "Exit short", shape.square, location.belowbar, color.new(color.orange, 0), text="EXIT", textcolor=color.white, size=size.tiny)
bgcolor(macro_en and regime == "D" ? color.new(color.red, 90) : na)
f_setlbl(lbl, cond, price, txt, col) =>
    label out = lbl
    if cond and not na(price)
        if na(out)
            out := label.new(bar_index + 2, price, txt, style=label.style_label_left, color=col, textcolor=color.white, size=size.small)
        label.set_xy(out, bar_index + 2, price)
        label.set_text(out, txt)
        label.set_color(out, col)
    else if not na(out)
        label.delete(out)
        out := na
    out
var label lbl_Le = na
var label lbl_Ls = na
var label lbl_Lt = na
var label lbl_Se = na
var label lbl_Ss = na
var label lbl_St = na
if barstate.islast and show_line_labels
    lbl_Le := f_setlbl(lbl_Le, l_live, Le, "▲ ENTRY " + str.tostring(Le, format.mintick), color.new(color.yellow, 0))
    lbl_Ls := f_setlbl(lbl_Ls, l_live, l_stop_now, (in_long ? "TRAIL " : "STOP ") + str.tostring(l_stop_now, format.mintick), color.new(color.red, 0))
    lbl_Lt := f_setlbl(lbl_Lt, l_live, Lt1, "TP1 " + str.tostring(Lt1, format.mintick) + " (debit cap)", color.new(color.green, 0))
    lbl_Se := f_setlbl(lbl_Se, s_live, Se, "▼ ENTRY " + str.tostring(Se, format.mintick), color.new(color.yellow, 0))
    lbl_Ss := f_setlbl(lbl_Ss, s_live, s_stop_now, (in_short ? "TRAIL " : "STOP ") + str.tostring(s_stop_now, format.mintick), color.new(color.red, 0))
    lbl_St := f_setlbl(lbl_St, s_live, St1, "TP1 " + str.tostring(St1, format.mintick) + " (debit cap)", color.new(color.green, 0))
alertcondition(long_fire,  "ORB Options LONG",  "HIGHSTRIKE ORB options: LONG — buy CALL (1-2 ITM) / call debit spread / put credit spread @ structure stop. 0DTE, max 4DTE hold.")
alertcondition(short_fire, "ORB Options SHORT", "HIGHSTRIKE ORB options: SHORT — buy PUT (1-2 ITM) / put debit spread / call credit spread @ structure stop. 0DTE, max 4DTE hold.")
alertcondition(exit_l or exit_s, "ORB Options EXIT", "HIGHSTRIKE ORB options: EXIT — underlying broke the trail; close the option/spread.")

// ───────────────────────── DASHBOARD (options translation only — the STACK chart carries the LONG|SHORT trade plan) ─────────────────────────
f_v(p) => na(p) ? "—" : f_px(p)
var table t = table.new(position.top_right, 3, 6, bgcolor=color.new(color.black, 60), frame_color=color.gray, frame_width=1, border_color=color.new(color.gray, 70), border_width=1)
if barstate.islast and show_table
    string dte_lbl = (est_dte == 0 ? "0DTE" : str.tostring(est_dte) + "DTE") + " ≤" + str.tostring(max_dte)
    string sttL = stL == "ARMED" ? "READY TO BUY" : stL
    string sttS = stS == "ARMED" ? "READY TO BUY" : stS
    table.cell(t, 0, 0, "OPTIONS " + syminfo.ticker + (sym_ok ? "" : " ⚠ SPY/QQQ"), text_color=color.yellow, text_size=size.small)
    table.cell(t, 1, 0, "LONG",  text_color=color.lime, text_size=size.small)
    table.cell(t, 2, 0, "SHORT", text_color=color.red,  text_size=size.small)
    table.cell(t, 0, 1, "OPT", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 1, na(kNl) ? "—" : syminfo.ticker + " " + f_px(kNl) + "C | " + dte_lbl, text_color=color.aqua, text_size=size.tiny)
    table.cell(t, 2, 1, na(kNs) ? "—" : syminfo.ticker + " " + f_px(kNs) + "P | " + dte_lbl, text_color=color.aqua, text_size=size.tiny)
    table.cell(t, 0, 2, "STRAT", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 2, na(kNl) ? "—" : f_strat(true, kNl, dsl, csl, cll), text_color=color.teal, text_size=size.tiny)
    table.cell(t, 2, 2, na(kNs) ? "—" : f_strat(false, kNs, dss, css, cls), text_color=color.teal, text_size=size.tiny)
    table.cell(t, 0, 3, "COST", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 3, na(kNl) ? "—" : f_cost(true, kNl, dsl, csl, cll), text_color=color.silver, text_size=size.tiny)
    table.cell(t, 2, 3, na(kNs) ? "—" : f_cost(false, kNs, dss, css, cls), text_color=color.silver, text_size=size.tiny)
    table.cell(t, 0, 4, "STATE", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 4, sttL, text_color=f_stc(stL), text_size=size.tiny)
    table.cell(t, 2, 4, sttS, text_color=f_stc(stS), text_size=size.tiny)
    table.cell(t, 0, 5, "EXP", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 5, exp_txt, text_color=color.gray, text_size=size.tiny)
    table.cell(t, 2, 5, est_on ? "COST ~est IV " + str.tostring(iv_pct, "#") + "% · real @ broker" : "price @ broker", text_color=color.gray, text_size=size.tiny)
