{
  "default_source": "yahoo",
  "active_market_data_file": "data/NQ_5min_data.csv",
  "active_profiles_file": "studies/macro_reaction_profiles_dabento_full_1m.csv",
  "active_reaction_files": [
    "studies/macro_reactions_dabento_full_1m.csv",
    "studies/macro_reactions_dabento_full_5m.csv",
    "studies/macro_reactions_dabento_full_60m.csv"
  ],
  "active_reaction_labels": [
    "dabento_full_1m",
    "dabento_full_5m",
    "dabento_full_60m"
  ],
  "yahoo": {
    "enabled": true,
    "ticker": "NQ=F",
    "preset": "intraday",
    "primary_intraday_interval": "5m",
    "refresh_on_runner": true,
    "notes": "Yahoo 5m refresh keeps the live tape regime current; throttled by --market-refresh-minutes. Dabento files remain the historical study source."
  },
  "daily_confirmation": {
    "enabled": true,
    "source_label": "investing_daily_clean",
    "profiles_file": "studies/macro_reaction_profiles_investing_daily.csv",
    "output": "macro_live_signal_current.csv",
    "notes": "Temporary daily baseline confirmation until deeper 1m/5m NQ history is available."
  },
  "external_api": {
    "enabled": false,
    "provider": "",
    "api_key_env": "",
    "normalized_output": "data/NQ_external_1min_data.csv",
    "notes": "Fill this later when a provider and API key are selected."
  }
}
